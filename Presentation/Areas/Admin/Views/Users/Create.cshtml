@model UserViewModel

@{
    ViewData["Title"] = "Add New User";
}

@section Styles{
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/admin/assets/vendors/select2/select2.min.css">
    <link rel="stylesheet" href="~/admin/assets/vendors/select2-bootstrap-theme/select2-bootstrap.min.css">
    <!-- End plugin css for this page -->
}

<div class="col-md-6 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Add New User</h4>
            <form class="forms-sample" method="post" asp-area="Admin" asp-controller="Users" asp-action="Create">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="UserName"></label>
                    <input asp-for="UserName" class="form-control" placeholder="Enter UserName">
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" placeholder="Enter Password">
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <select class="js-example-basic-single select2-hidden-accessible" style="width:100%" asp-for="RoleName" asp-items="ViewBag.Roles">
                    <option value="">-- Select Role --</option>
                </select>


                <button type="submit" class="btn btn-gradient-primary me-2 mt-5" onclick="return confirm('Are you sure you want to save the values?');">Create</button>
                <button type="reset" class="btn btn-dark mt-5">Clear</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/admin/assets/vendors/select2/select2.min.js"></script>
    <script src="~/admin/assets/js/select2.js"></script>
    @* <partial name="_ValidationScriptsPartial"></partial> *@
}