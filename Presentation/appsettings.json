{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=SwiftLaneDB;Trusted_Connection=true;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "DefaultConnection",
          "sinkOptionsSection": {
            "tableName": "Logs",
            "schemaName": "dbo",
            "autoCreateSqlTable": true
          },
          "restrictedToMinimumLevel": "Information",
          "columnOptionsSection": {
            "additionalColumns": [
              {
                "ColumnName": "SourceContext",
                "DataType": "nvarchar",
                "DataLength": 200,
                "PropertyName": "SourceContext"
              }
            ]
          }
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
